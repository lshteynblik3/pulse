{
  "name": "pulse",
  "version": "0.0.0",
  "private": true,
  "description": "Pulse — privacy-first focus & productivity tracking (monorepo root)",
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "pnpm -r run typecheck",
    "dev:web": "pnpm --filter @pulse/web dev",
    "build:web": "pnpm --filter @pulse/web build",
    "dev:agent": "pnpm --filter @pulse/agent dev"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "active-win"]
  }
}
