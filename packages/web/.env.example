# Pulse web — environment variables.
# Copy this file to `.env.local` (which is gitignored) and fill in real values.
#
# Both values come from the Supabase dashboard:
#   Settings → API (or "Project Settings → Data API" + "API Keys")
#
# SUPABASE_SERVICE_ROLE_KEY is a SECRET that bypasses Row Level Security.
# It is used only in server-side API routes. Never expose it to the browser and
# never commit your real .env.local.

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
