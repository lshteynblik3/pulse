# Pulse web — environment variables.
# Copy this file to `.env.local` (which is gitignored) and fill in real values.
#
# Both values come from the Supabase dashboard:
#   Settings → API (or "Project Settings → Data API" + "API Keys")
#
# SUPABASE_SERVICE_ROLE_KEY is a SECRET that bypasses Row Level Security.
# It is used only in server-side API routes. Never expose it to the browser and
# never commit your real .env.local.

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth (Phase 4a) — these two are PUBLIC by design (the NEXT_PUBLIC_ prefix ships
# them to the browser). The anon key is safe to expose: Row Level Security is what
# actually protects the data. Both come from the same Supabase dashboard page as
# the values above (Settings → API). The URL is the same project URL as
# SUPABASE_URL; it's duplicated under a public name so the browser/SSR auth client
# can read it.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Phase 5 — AI insights worker (server-only secrets; never ship to the browser).
# ANTHROPIC_API_KEY: the Claude API key used by the nightly insights batch (Haiku 4.5).
# CRON_SECRET: a shared secret. Set it in the Vercel project; Vercel then sends it as
#   `Authorization: Bearer <CRON_SECRET>` on cron invocations, and the cron routes
#   reject any request that doesn't match — so the paid, service-role insights crons
#   can't be triggered by anyone else.
ANTHROPIC_API_KEY=sk-ant-your-key
CRON_SECRET=a-long-random-string
